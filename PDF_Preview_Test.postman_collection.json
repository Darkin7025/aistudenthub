{
  "info": {
    "name": "PDF Preview Testing",
    "description": "Test PDF upload và preview functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
              "    pm.environment.set('accessToken', jsonData.data.accessToken);",
              "    console.log('Token saved:', jsonData.data.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. Upload PDF",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const jsonData = pm.response.json();",
              "    pm.collectionVariables.set('documentId', jsonData.data.id);",
              "    pm.environment.set('documentId', jsonData.data.id);",
              "    console.log('Document ID:', jsonData.data.id);",
              "    console.log('File URL:', jsonData.data.fileUrl);",
              "    ",
              "    // Verify response",
              "    pm.test('Upload status is COMPLETED', () => {",
              "        pm.expect(jsonData.data.uploadStatus).to.eql('COMPLETED');",
              "    });",
              "    ",
              "    pm.test('File type is application/pdf', () => {",
              "        pm.expect(jsonData.data.fileType).to.eql('application/pdf');",
              "    });",
              "    ",
              "    pm.test('File URL exists', () => {",
              "        pm.expect(jsonData.data.fileUrl).to.be.a('string');",
              "        pm.expect(jsonData.data.fileUrl).to.include('cloudinary');",
              "    });",
              "    ",
              "    pm.test('Preview mode is PDF', () => {",
              "        pm.expect(jsonData.data.previewMode).to.eql('PDF');",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "/path/to/lab1.pdf",
              "description": "Upload your PDF file here"
            },
            {
              "key": "request",
              "value": "{\n  \"title\": \"Lab 1 PDF Test\",\n  \"description\": \"Testing PDF preview functionality\",\n  \"subject\": \"Computer Science\"\n}",
              "type": "text",
              "contentType": "application/json"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/upload",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "upload"]
        }
      },
      "response": []
    },
    {
      "name": "3. Get Document Details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    pm.test('Document has fileUrl', () => {",
              "        pm.expect(jsonData.data.fileUrl).to.be.a('string');",
              "        pm.expect(jsonData.data.fileUrl.length).to.be.above(0);",
              "    });",
              "    ",
              "    pm.test('File type is PDF', () => {",
              "        pm.expect(jsonData.data.fileType).to.eql('application/pdf');",
              "    });",
              "    ",
              "    console.log('Document Details:', JSON.stringify(jsonData.data, null, 2));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}"]
        }
      },
      "response": []
    },
    {
      "name": "4. Get Preview (Owner)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    pm.test('Preview mode is PDF', () => {",
              "        pm.expect(jsonData.data.previewMode).to.eql('PDF');",
              "    });",
              "    ",
              "    pm.test('Preview is supported', () => {",
              "        pm.expect(jsonData.data.previewSupported).to.be.true;",
              "    });",
              "    ",
              "    pm.test('Preview URL exists', () => {",
              "        pm.expect(jsonData.data.previewUrl).to.be.a('string');",
              "        pm.expect(jsonData.data.previewUrl).to.include('cloudinary');",
              "    });",
              "    ",
              "    pm.test('File name matches', () => {",
              "        pm.expect(jsonData.data.fileName).to.include('.pdf');",
              "    });",
              "    ",
              "    pm.test('File type is application/pdf', () => {",
              "        pm.expect(jsonData.data.fileType).to.eql('application/pdf');",
              "    });",
              "    ",
              "    pm.test('Message is helpful', () => {",
              "        pm.expect(jsonData.data.message).to.be.a('string');",
              "        pm.expect(jsonData.data.message.length).to.be.above(0);",
              "    });",
              "    ",
              "    console.log('\\n=== PREVIEW RESPONSE ===');",
              "    console.log(JSON.stringify(jsonData.data, null, 2));",
              "    console.log('\\n📎 Copy this URL to browser to test:');",
              "    console.log(jsonData.data.previewUrl);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/preview",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}", "preview"]
        }
      },
      "response": []
    },
    {
      "name": "5. Download PDF",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    pm.test('Download URL exists', () => {",
              "        pm.expect(jsonData.data).to.be.a('string');",
              "        pm.expect(jsonData.data).to.include('cloudinary');",
              "    });",
              "    ",
              "    console.log('\\n📥 Download URL:', jsonData.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/download",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}", "download"]
        }
      },
      "response": []
    },
    {
      "name": "6. Test Permission (No Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should return 401 Unauthorized', () => {",
              "    pm.expect(pm.response.code).to.eql(401);",
              "});",
              "",
              "console.log('✅ Correctly rejected unauthorized access');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/preview",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}", "preview"]
        }
      },
      "response": []
    },
    {
      "name": "7. Test Wrong Document ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should return 404 or 403', () => {",
              "    pm.expect([403, 404]).to.include(pm.response.code);",
              "});",
              "",
              "console.log('✅ Correctly handled invalid document ID');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/00000000-0000-0000-0000-000000000000/preview",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "00000000-0000-0000-0000-000000000000", "preview"]
        }
      },
      "response": []
    },
    {
      "name": "8. Get My Documents",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    pm.test('Returns array of documents', () => {",
              "        pm.expect(jsonData.data).to.be.an('array');",
              "    });",
              "    ",
              "    if (jsonData.data.length > 0) {",
              "        pm.test('First document has required fields', () => {",
              "            const doc = jsonData.data[0];",
              "            pm.expect(doc).to.have.property('id');",
              "            pm.expect(doc).to.have.property('title');",
              "            pm.expect(doc).to.have.property('fileUrl');",
              "            pm.expect(doc).to.have.property('previewMode');",
              "        });",
              "    }",
              "    ",
              "    console.log(`\\n📄 Found ${jsonData.data.length} documents`);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/my",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "my"]
        }
      },
      "response": []
    }
  ]
}
